# Renombra este archivo a ".env" y coloca tus valores reales
GOVEE_API_KEY=tu_api_key_aqui

# Mapeo de gateways por prefijo de MAC: NombreGW:PREFIJO
# Ejemplo: GW1:D0:C9:07,GW2:A4:C1:38
GATEWAY_MAP=GW1:D0:C9:07

# Ruta de la base de datos SQLite
DB_PATH=govee_history.db

# Ruta del archivo de agrupaciones
GROUPS_FILE=groups.json
